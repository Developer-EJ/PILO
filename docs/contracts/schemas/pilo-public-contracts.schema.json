{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pilo.local/contracts/pilo-public-contracts.schema.json",
  "title": "PILO Public Contracts",
  "type": "object",
  "$defs": {
    "uuid": {
      "type": "string",
      "format": "uuid"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "memberRef": {
      "type": "object",
      "required": ["memberId", "name"],
      "additionalProperties": false,
      "properties": {
        "memberId": { "$ref": "#/$defs/uuid" },
        "userId": { "$ref": "#/$defs/uuid" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "avatarUrl": { "type": ["string", "null"] }
      }
    },
    "CurrentUser": {
      "type": "object",
      "required": ["id", "email", "name", "providers"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "avatarUrl": { "type": ["string", "null"] },
        "providers": {
          "type": "array",
          "items": { "enum": ["google", "github"] }
        },
        "lastLoginAt": { "anyOf": [{ "$ref": "#/$defs/dateTime" }, { "type": "null" }] }
      }
    },
    "WorkspaceSummary": {
      "type": "object",
      "required": ["id", "name", "status", "myRole", "memberCount"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "name": { "type": "string" },
        "description": { "type": ["string", "null"] },
        "type": { "enum": ["side_project", "bootcamp", "university", "hackathon", "other"] },
        "status": { "enum": ["active", "archived"] },
        "myRole": { "enum": ["owner", "member", "viewer"] },
        "memberCount": { "type": "integer", "minimum": 0 },
        "createdAt": { "$ref": "#/$defs/dateTime" }
      }
    },
    "WorkspaceMemberSummary": {
      "type": "object",
      "required": ["memberId", "userId", "name", "email", "role"],
      "additionalProperties": false,
      "properties": {
        "memberId": { "$ref": "#/$defs/uuid" },
        "userId": { "$ref": "#/$defs/uuid" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "avatarUrl": { "type": ["string", "null"] },
        "role": { "enum": ["owner", "member", "viewer"] },
        "displayName": { "type": ["string", "null"] },
        "joinedAt": { "$ref": "#/$defs/dateTime" }
      }
    },
    "TaskSummary": {
      "type": "object",
      "required": ["id", "workspaceId", "title", "status", "priority", "isDelayed"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "workspaceId": { "$ref": "#/$defs/uuid" },
        "title": { "type": "string" },
        "status": { "enum": ["todo", "in_progress", "in_review", "done", "blocked"] },
        "priority": { "enum": ["low", "medium", "high", "urgent"] },
        "assignee": { "anyOf": [{ "$ref": "#/$defs/memberRef" }, { "type": "null" }] },
        "dueDate": { "anyOf": [{ "$ref": "#/$defs/date" }, { "type": "null" }] },
        "isDelayed": { "type": "boolean" },
        "linkedIssueCount": { "type": "integer", "minimum": 0 },
        "linkedPrCount": { "type": "integer", "minimum": 0 },
        "updatedAt": { "$ref": "#/$defs/dateTime" }
      }
    },
    "TaskCreateDraft": {
      "type": "object",
      "required": ["workspaceId", "title"],
      "additionalProperties": false,
      "properties": {
        "workspaceId": { "$ref": "#/$defs/uuid" },
        "sourceType": { "type": "string" },
        "sourceId": { "$ref": "#/$defs/uuid" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": ["string", "null"] },
        "assigneeMemberId": { "anyOf": [{ "$ref": "#/$defs/uuid" }, { "type": "null" }] },
        "priority": { "enum": ["low", "medium", "high", "urgent"] },
        "dueDate": { "anyOf": [{ "$ref": "#/$defs/date" }, { "type": "null" }] }
      }
    },
    "TaskDraft": {
      "type": "object",
      "required": ["id", "workspaceId", "title", "priority", "status", "createdAt"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "workspaceId": { "$ref": "#/$defs/uuid" },
        "sourceType": { "type": ["string", "null"] },
        "sourceId": { "anyOf": [{ "$ref": "#/$defs/uuid" }, { "type": "null" }] },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": ["string", "null"] },
        "assigneeMemberId": { "anyOf": [{ "$ref": "#/$defs/uuid" }, { "type": "null" }] },
        "priority": { "enum": ["low", "medium", "high", "urgent"] },
        "dueDate": { "anyOf": [{ "$ref": "#/$defs/date" }, { "type": "null" }] },
        "status": { "enum": ["draft", "waiting_confirmation", "approved", "rejected"] },
        "createdAt": { "$ref": "#/$defs/dateTime" }
      }
    },
    "MilestoneSummary": {
      "type": "object",
      "required": ["id", "workspaceId", "title", "status", "taskCount", "doneTaskCount"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "workspaceId": { "$ref": "#/$defs/uuid" },
        "title": { "type": "string" },
        "startDate": { "anyOf": [{ "$ref": "#/$defs/date" }, { "type": "null" }] },
        "endDate": { "anyOf": [{ "$ref": "#/$defs/date" }, { "type": "null" }] },
        "status": { "enum": ["planned", "in_progress", "done"] },
        "taskCount": { "type": "integer", "minimum": 0 },
        "doneTaskCount": { "type": "integer", "minimum": 0 }
      }
    },
    "TaskStatusUpdateAction": {
      "type": "object",
      "required": ["workspaceId", "taskId", "status"],
      "additionalProperties": false,
      "properties": {
        "workspaceId": { "$ref": "#/$defs/uuid" },
        "taskId": { "$ref": "#/$defs/uuid" },
        "status": { "enum": ["todo", "in_progress", "in_review", "done", "blocked"] }
      }
    },
    "ProgressSummary": {
      "type": "object",
      "required": ["workspaceId", "totalTasks", "doneTasks", "blockedTasks", "reviewTasks", "delayedTasks", "progressRate"],
      "additionalProperties": false,
      "properties": {
        "workspaceId": { "$ref": "#/$defs/uuid" },
        "milestoneId": { "anyOf": [{ "$ref": "#/$defs/uuid" }, { "type": "null" }] },
        "totalTasks": { "type": "integer", "minimum": 0 },
        "doneTasks": { "type": "integer", "minimum": 0 },
        "blockedTasks": { "type": "integer", "minimum": 0 },
        "reviewTasks": { "type": "integer", "minimum": 0 },
        "delayedTasks": { "type": "integer", "minimum": 0 },
        "progressRate": { "type": "number", "minimum": 0, "maximum": 100 },
        "capturedAt": { "$ref": "#/$defs/dateTime" }
      }
    },
    "ProgressSnapshotSummary": {
      "type": "object",
      "required": ["id", "workspaceId", "totalTasks", "doneTasks", "blockedTasks", "reviewTasks", "delayedTasks", "progressRate", "capturedAt"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "workspaceId": { "$ref": "#/$defs/uuid" },
        "milestoneId": { "anyOf": [{ "$ref": "#/$defs/uuid" }, { "type": "null" }] },
        "totalTasks": { "type": "integer", "minimum": 0 },
        "doneTasks": { "type": "integer", "minimum": 0 },
        "blockedTasks": { "type": "integer", "minimum": 0 },
        "reviewTasks": { "type": "integer", "minimum": 0 },
        "delayedTasks": { "type": "integer", "minimum": 0 },
        "progressRate": { "type": "number", "minimum": 0, "maximum": 100 },
        "capturedAt": { "$ref": "#/$defs/dateTime" }
      }
    },
    "GithubConnectionSummary": {
      "type": "object",
      "required": ["id", "workspaceId", "provider", "connectedAt"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "workspaceId": { "$ref": "#/$defs/uuid" },
        "provider": { "enum": ["github_app"] },
        "installationId": { "type": ["string", "null"] },
        "githubAccountLogin": { "type": ["string", "null"] },
        "scopes": { "type": "array", "items": { "type": "string" } },
        "connectedAt": { "$ref": "#/$defs/dateTime" },
        "revokedAt": { "anyOf": [{ "$ref": "#/$defs/dateTime" }, { "type": "null" }] }
      }
    },
    "GithubRepositorySummary": {
      "type": "object",
      "required": ["id", "workspaceId", "owner", "repoName", "url"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "workspaceId": { "$ref": "#/$defs/uuid" },
        "owner": { "type": "string" },
        "repoName": { "type": "string" },
        "url": { "type": "string" },
        "defaultBranch": { "type": ["string", "null"] },
        "syncedAt": { "anyOf": [{ "$ref": "#/$defs/dateTime" }, { "type": "null" }] }
      }
    },
    "GithubIssueSummary": {
      "type": "object",
      "required": ["id", "repositoryId", "number", "title", "state", "url"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "repositoryId": { "$ref": "#/$defs/uuid" },
        "number": { "type": "integer", "minimum": 1 },
        "title": { "type": "string" },
        "state": { "enum": ["open", "closed"] },
        "url": { "type": "string" },
        "labels": { "type": "array", "items": { "type": "string" } },
        "linkedTaskId": { "anyOf": [{ "$ref": "#/$defs/uuid" }, { "type": "null" }] },
        "syncedAt": { "anyOf": [{ "$ref": "#/$defs/dateTime" }, { "type": "null" }] }
      }
    },
    "PullRequestSummary": {
      "type": "object",
      "required": ["id", "repositoryId", "number", "title", "state", "url"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "repositoryId": { "$ref": "#/$defs/uuid" },
        "number": { "type": "integer", "minimum": 1 },
        "title": { "type": "string" },
        "authorLogin": { "type": ["string", "null"] },
        "state": { "enum": ["open", "review_requested", "changes_requested", "merged", "closed"] },
        "branch": { "type": ["string", "null"] },
        "baseBranch": { "type": ["string", "null"] },
        "url": { "type": "string" },
        "changedFilesCount": { "type": "integer", "minimum": 0 },
        "additions": { "type": "integer", "minimum": 0 },
        "deletions": { "type": "integer", "minimum": 0 },
        "linkedTaskIds": { "type": "array", "items": { "$ref": "#/$defs/uuid" } },
        "syncedAt": { "anyOf": [{ "$ref": "#/$defs/dateTime" }, { "type": "null" }] }
      }
    },
    "PullRequestChangedFileSummary": {
      "type": "object",
      "required": ["pullRequestId", "path", "status", "additions", "deletions", "changes", "patch", "sha", "sourceSyncedAt"],
      "additionalProperties": false,
      "properties": {
        "pullRequestId": { "$ref": "#/$defs/uuid" },
        "path": { "type": "string", "minLength": 1 },
        "previousPath": { "type": ["string", "null"] },
        "status": { "enum": ["added", "modified", "removed", "renamed", "copied", "changed", "unchanged"] },
        "additions": { "type": "integer", "minimum": 0 },
        "deletions": { "type": "integer", "minimum": 0 },
        "changes": { "type": "integer", "minimum": 0 },
        "patch": { "type": ["string", "null"] },
        "sha": { "type": "string", "minLength": 1 },
        "blobUrl": { "type": ["string", "null"] },
        "rawUrl": { "type": ["string", "null"] },
        "sourceSyncedAt": { "$ref": "#/$defs/dateTime" }
      }
    },
    "GithubIssueCreateAction": {
      "type": "object",
      "required": ["workspaceId", "repositoryId", "title"],
      "additionalProperties": false,
      "properties": {
        "workspaceId": { "$ref": "#/$defs/uuid" },
        "repositoryId": { "$ref": "#/$defs/uuid" },
        "taskId": { "anyOf": [{ "$ref": "#/$defs/uuid" }, { "type": "null" }] },
        "title": { "type": "string", "minLength": 1 },
        "body": { "type": ["string", "null"] },
        "labels": { "type": "array", "items": { "type": "string" } }
      }
    },
    "MeetingReportGenerateAction": {
      "type": "object",
      "required": ["workspaceId", "meetingId"],
      "additionalProperties": false,
      "properties": {
        "workspaceId": { "$ref": "#/$defs/uuid" },
        "meetingId": { "$ref": "#/$defs/uuid" }
      }
    },
    "ReviewAnalysisGenerateAction": {
      "type": "object",
      "required": ["workspaceId", "pullRequestId"],
      "additionalProperties": false,
      "properties": {
        "workspaceId": { "$ref": "#/$defs/uuid" },
        "pullRequestId": { "$ref": "#/$defs/uuid" }
      }
    },
    "PlanningApproveAction": {
      "type": "object",
      "required": ["workspaceId", "draftId"],
      "additionalProperties": false,
      "properties": {
        "workspaceId": { "$ref": "#/$defs/uuid" },
        "draftId": { "$ref": "#/$defs/uuid" }
      }
    },
    "MeetingReportSummary": {
      "type": "object",
      "required": ["id", "meetingId", "workspaceId", "title", "summary", "decisionCount", "actionItemCount", "riskCount"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "meetingId": { "$ref": "#/$defs/uuid" },
        "workspaceId": { "$ref": "#/$defs/uuid" },
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "decisionCount": { "type": "integer", "minimum": 0 },
        "actionItemCount": { "type": "integer", "minimum": 0 },
        "riskCount": { "type": "integer", "minimum": 0 },
        "createdAt": { "$ref": "#/$defs/dateTime" }
      }
    },
    "MeetingActionItem": {
      "type": "object",
      "required": ["id", "reportId", "title", "status"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "reportId": { "$ref": "#/$defs/uuid" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": ["string", "null"] },
        "assigneeSuggestionMemberId": { "anyOf": [{ "$ref": "#/$defs/uuid" }, { "type": "null" }] },
        "dueDateSuggestion": { "anyOf": [{ "$ref": "#/$defs/date" }, { "type": "null" }] },
        "status": { "enum": ["draft", "approved", "converted", "rejected"] },
        "convertedTaskId": { "anyOf": [{ "$ref": "#/$defs/uuid" }, { "type": "null" }] }
      }
    },
    "PRAnalysisSummary": {
      "type": "object",
      "required": ["id", "pullRequestId", "riskLevel", "analysisStatus", "okCount", "discussCount", "riskCount"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "pullRequestId": { "$ref": "#/$defs/uuid" },
        "purposeSummary": { "type": ["string", "null"] },
        "impactSummary": { "type": ["string", "null"] },
        "testRecommendation": { "type": ["string", "null"] },
        "riskLevel": { "enum": ["low", "medium", "high", "critical"], "default": "low" },
        "analysisStatus": { "enum": ["pending", "running", "succeeded", "failed"], "default": "pending" },
        "okCount": { "type": "integer", "minimum": 0, "default": 0 },
        "discussCount": { "type": "integer", "minimum": 0, "default": 0 },
        "riskCount": { "type": "integer", "minimum": 0, "default": 0 },
        "conclusion": { "type": ["string", "null"] }
      }
    },
    "ReviewCanvasSummary": {
      "type": "object",
      "required": ["id", "analysisId", "pullRequestId", "intentSummary", "reviewStrategy", "nodes", "edges"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "analysisId": { "$ref": "#/$defs/uuid" },
        "pullRequestId": { "$ref": "#/$defs/uuid" },
        "intentSummary": { "type": "string", "minLength": 1 },
        "reviewStrategy": { "type": "string", "minLength": 1 },
        "nodes": { "type": "array", "items": { "$ref": "#/$defs/ReviewCanvasNode" } },
        "edges": { "type": "array", "items": { "$ref": "#/$defs/ReviewCanvasEdge" } }
      }
    },
    "ReviewCanvasNode": {
      "type": "object",
      "required": ["id", "analysisId", "nodeType", "label", "riskLevel", "status", "reviewOrder", "roleSummary", "reviewReason", "position"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "analysisId": { "$ref": "#/$defs/uuid" },
        "nodeType": { "enum": ["file", "function", "api", "schema", "risk", "impact"] },
        "label": { "type": "string", "minLength": 1 },
        "filePath": { "type": ["string", "null"] },
        "functionName": { "type": ["string", "null"] },
        "riskLevel": { "enum": ["low", "medium", "high", "critical"] },
        "status": { "enum": ["ok", "discuss", "unknown"] },
        "reviewOrder": { "type": "integer", "minimum": 1 },
        "roleSummary": { "type": "string", "minLength": 1 },
        "reviewReason": { "type": "string", "minLength": 1 },
        "position": {
          "type": "object",
          "required": ["x", "y"],
          "additionalProperties": false,
          "properties": {
            "x": { "type": "integer" },
            "y": { "type": "integer" }
          }
        }
      }
    },
    "ReviewCanvasEdge": {
      "type": "object",
      "required": ["id", "sourceNodeId", "targetNodeId"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "sourceNodeId": { "$ref": "#/$defs/uuid" },
        "targetNodeId": { "$ref": "#/$defs/uuid" },
        "label": { "type": ["string", "null"] }
      }
    },
    "ReviewNodeDetail": {
      "type": "object",
      "required": ["id", "analysisId", "nodeId", "filePath", "roleSummary", "modificationReason", "changeGroups", "diffHunks"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "analysisId": { "$ref": "#/$defs/uuid" },
        "nodeId": { "$ref": "#/$defs/uuid" },
        "filePath": { "type": "string", "minLength": 1 },
        "roleSummary": { "type": "string", "minLength": 1 },
        "modificationReason": { "type": "string", "minLength": 1 },
        "changeGroups": { "type": "array", "items": { "$ref": "#/$defs/ReviewChangeGroup" } },
        "diffHunks": { "type": "array", "items": { "$ref": "#/$defs/ReviewDiffHunk" } }
      }
    },
    "ReviewChangeGroup": {
      "type": "object",
      "required": ["id", "title", "summary", "newStartLine"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "newStartLine": { "type": "integer", "minimum": 1 },
        "newEndLine": { "type": ["integer", "null"], "minimum": 1 }
      }
    },
    "ReviewDiffHunk": {
      "type": "object",
      "required": ["id", "oldStartLine", "newStartLine", "oldCode", "newCode"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "oldStartLine": { "type": "integer", "minimum": 1 },
        "newStartLine": { "type": "integer", "minimum": 1 },
        "oldCode": { "type": "string" },
        "newCode": { "type": "string" },
        "highlightLines": { "type": "array", "items": { "type": "integer", "minimum": 1 } }
      }
    },
    "ReviewNodeSummary": {
      "type": "object",
      "required": ["id", "analysisId", "nodeType", "label", "riskLevel", "status"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "analysisId": { "$ref": "#/$defs/uuid" },
        "nodeType": { "enum": ["file", "function", "api", "schema", "risk", "impact"] },
        "label": { "type": "string", "minLength": 1 },
        "filePath": { "type": ["string", "null"] },
        "functionName": { "type": ["string", "null"] },
        "riskLevel": { "enum": ["low", "medium", "high", "critical"] },
        "status": { "enum": ["ok", "discuss", "unknown"] }
      }
    },
    "ReviewRiskSummary": {
      "type": "object",
      "required": ["id", "analysisId", "title", "riskLevel", "status", "affectedNodeIds"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "analysisId": { "$ref": "#/$defs/uuid" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": ["string", "null"] },
        "riskLevel": { "enum": ["low", "medium", "high", "critical"] },
        "status": { "enum": ["open", "resolved", "accepted"] },
        "affectedNodeIds": { "type": "array", "items": { "$ref": "#/$defs/uuid" } },
        "recommendation": { "type": ["string", "null"] }
      }
    },
    "CanvasEntityRef": {
      "type": "object",
      "required": ["entityType", "entityId", "displayTitle", "shapeType"],
      "additionalProperties": false,
      "properties": {
        "entityType": { "enum": ["task", "meeting_report", "pull_request", "github_issue", "document", "file", "code", "decision", "risk"] },
        "entityId": { "$ref": "#/$defs/uuid" },
        "displayTitle": { "type": "string" },
        "shapeType": { "enum": ["task", "meeting_report", "pull_request", "github_issue", "document", "file", "code", "decision", "risk"] }
      }
    },
    "AgentWorkflowType": {
      "enum": ["meeting.report.generate", "review.analysis.generate", "planning.generate", "task.draft.generate", "github.issue.draft.generate", "orchestrator.run"]
    },
    "AgentRunStatus": {
      "enum": ["pending", "running", "succeeded", "failed", "requires_confirmation"]
    },
    "AgentRunStepStatus": {
      "enum": ["pending", "running", "succeeded", "failed"]
    },
    "AgentError": {
      "type": "object",
      "required": ["message"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": ["string", "null"] },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "AgentTokenUsage": {
      "type": "object",
      "required": ["inputTokens", "outputTokens", "totalTokens"],
      "additionalProperties": false,
      "properties": {
        "inputTokens": { "type": "integer", "minimum": 0 },
        "outputTokens": { "type": "integer", "minimum": 0 },
        "totalTokens": { "type": "integer", "minimum": 0 },
        "model": { "type": ["string", "null"] }
      }
    },
    "AgentContextRef": {
      "type": "object",
      "required": ["type", "id"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "id": { "$ref": "#/$defs/uuid" }
      }
    },
    "AgentRunCreateRequest": {
      "type": "object",
      "required": ["workspaceId", "workflowType", "input", "contextRefs"],
      "additionalProperties": false,
      "properties": {
        "workspaceId": { "$ref": "#/$defs/uuid" },
        "workflowType": { "$ref": "#/$defs/AgentWorkflowType" },
        "workflowVersion": { "type": "string", "minLength": 1 },
        "input": { "type": "object" },
        "contextRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/AgentContextRef" }
        }
      }
    },
    "AgentRunStatusResponse": {
      "type": "object",
      "required": ["id", "workspaceId", "workflowType", "workflowVersion", "status", "actionRequired", "pendingActionCount", "startedAt", "finishedAt", "updatedAt", "error"],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "required": ["status"],
            "properties": {
              "status": { "const": "failed" }
            }
          },
          "then": {
            "properties": {
              "error": { "$ref": "#/$defs/AgentError" }
            }
          }
        },
        {
          "if": {
            "required": ["status"],
            "properties": {
              "status": { "enum": ["pending", "running", "succeeded", "requires_confirmation"] }
            }
          },
          "then": {
            "properties": {
              "error": { "type": "null" }
            }
          }
        },
        {
          "if": {
            "required": ["status"],
            "properties": {
              "status": { "const": "requires_confirmation" }
            }
          },
          "then": {
            "properties": {
              "actionRequired": { "const": true },
              "pendingActionCount": { "type": "integer", "minimum": 1 }
            }
          }
        }
      ],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "workspaceId": { "$ref": "#/$defs/uuid" },
        "workflowType": { "$ref": "#/$defs/AgentWorkflowType" },
        "workflowVersion": { "type": "string", "minLength": 1 },
        "status": { "$ref": "#/$defs/AgentRunStatus" },
        "actionRequired": { "type": "boolean" },
        "pendingActionCount": { "type": "integer", "minimum": 0 },
        "startedAt": { "anyOf": [{ "$ref": "#/$defs/dateTime" }, { "type": "null" }] },
        "finishedAt": { "anyOf": [{ "$ref": "#/$defs/dateTime" }, { "type": "null" }] },
        "updatedAt": { "$ref": "#/$defs/dateTime" },
        "error": { "anyOf": [{ "$ref": "#/$defs/AgentError" }, { "type": "null" }] }
      }
    },
    "AgentRunStepDetail": {
      "type": "object",
      "required": ["id", "runId", "stepName", "status", "input", "output", "error", "tokenUsage", "startedAt", "finishedAt", "createdAt"],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "required": ["status"],
            "properties": {
              "status": { "const": "failed" }
            }
          },
          "then": {
            "properties": {
              "error": { "$ref": "#/$defs/AgentError" }
            }
          }
        },
        {
          "if": {
            "required": ["status"],
            "properties": {
              "status": { "enum": ["pending", "running", "succeeded"] }
            }
          },
          "then": {
            "properties": {
              "error": { "type": "null" }
            }
          }
        }
      ],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "runId": { "$ref": "#/$defs/uuid" },
        "stepName": { "type": "string", "minLength": 1 },
        "status": { "$ref": "#/$defs/AgentRunStepStatus" },
        "input": { "type": "object" },
        "output": { "type": ["object", "null"] },
        "error": { "anyOf": [{ "$ref": "#/$defs/AgentError" }, { "type": "null" }] },
        "tokenUsage": { "anyOf": [{ "$ref": "#/$defs/AgentTokenUsage" }, { "type": "null" }] },
        "startedAt": { "anyOf": [{ "$ref": "#/$defs/dateTime" }, { "type": "null" }] },
        "finishedAt": { "anyOf": [{ "$ref": "#/$defs/dateTime" }, { "type": "null" }] },
        "createdAt": { "$ref": "#/$defs/dateTime" }
      }
    },
    "AgentTraceEntry": {
      "type": "object",
      "required": ["id", "runId", "stepId", "message", "metadata", "createdAt"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "runId": { "$ref": "#/$defs/uuid" },
        "stepId": { "anyOf": [{ "$ref": "#/$defs/uuid" }, { "type": "null" }] },
        "message": { "type": "string", "minLength": 1 },
        "metadata": { "type": "object" },
        "createdAt": { "$ref": "#/$defs/dateTime" }
      }
    },
    "AgentRunDetail": {
      "type": "object",
      "required": ["id", "workflowId", "workflowType", "workflowVersion", "workspaceId", "actorMemberId", "status", "actionRequired", "pendingActionCount", "input", "output", "error", "tokenUsage", "steps", "actions", "trace", "startedAt", "finishedAt", "createdAt", "updatedAt"],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "required": ["status"],
            "properties": {
              "status": { "const": "failed" }
            }
          },
          "then": {
            "properties": {
              "error": { "$ref": "#/$defs/AgentError" }
            }
          }
        },
        {
          "if": {
            "required": ["status"],
            "properties": {
              "status": { "enum": ["pending", "running", "succeeded", "requires_confirmation"] }
            }
          },
          "then": {
            "properties": {
              "error": { "type": "null" }
            }
          }
        },
        {
          "if": {
            "required": ["status"],
            "properties": {
              "status": { "const": "requires_confirmation" }
            }
          },
          "then": {
            "properties": {
              "actionRequired": { "const": true },
              "pendingActionCount": { "type": "integer", "minimum": 1 }
            }
          }
        }
      ],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "workflowId": { "$ref": "#/$defs/uuid" },
        "workflowType": { "$ref": "#/$defs/AgentWorkflowType" },
        "workflowVersion": { "type": "string", "minLength": 1 },
        "workspaceId": { "$ref": "#/$defs/uuid" },
        "actorMemberId": { "$ref": "#/$defs/uuid" },
        "status": { "$ref": "#/$defs/AgentRunStatus" },
        "actionRequired": { "type": "boolean" },
        "pendingActionCount": { "type": "integer", "minimum": 0 },
        "input": { "type": "object" },
        "output": { "type": ["object", "null"] },
        "error": { "anyOf": [{ "$ref": "#/$defs/AgentError" }, { "type": "null" }] },
        "tokenUsage": { "anyOf": [{ "$ref": "#/$defs/AgentTokenUsage" }, { "type": "null" }] },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/$defs/AgentRunStepDetail" }
        },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/AgentAction" }
        },
        "trace": {
          "type": "array",
          "items": { "$ref": "#/$defs/AgentTraceEntry" }
        },
        "startedAt": { "anyOf": [{ "$ref": "#/$defs/dateTime" }, { "type": "null" }] },
        "finishedAt": { "anyOf": [{ "$ref": "#/$defs/dateTime" }, { "type": "null" }] },
        "createdAt": { "$ref": "#/$defs/dateTime" },
        "updatedAt": { "$ref": "#/$defs/dateTime" }
      }
    },
    "AgentActionCommon": {
      "type": "object",
      "required": ["id", "runId", "type", "source", "requiresConfirmation", "payload", "status", "confirmedByMemberId", "confirmedAt", "executedAt"],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "required": ["requiresConfirmation"],
            "properties": {
              "requiresConfirmation": { "const": false }
            }
          },
          "then": {
            "properties": {
              "status": { "enum": ["draft", "executed"] },
              "confirmedByMemberId": { "type": "null" },
              "confirmedAt": { "type": "null" }
            }
          }
        },
        {
          "if": {
            "required": ["status"],
            "properties": {
              "status": { "const": "draft" }
            }
          },
          "then": {
            "properties": {
              "confirmedByMemberId": { "type": "null" },
              "confirmedAt": { "type": "null" },
              "executedAt": { "type": "null" }
            }
          }
        },
        {
          "if": {
            "required": ["status"],
            "properties": {
              "status": { "const": "waiting_confirmation" }
            }
          },
          "then": {
            "properties": {
              "requiresConfirmation": { "const": true },
              "confirmedByMemberId": { "type": "null" },
              "confirmedAt": { "type": "null" },
              "executedAt": { "type": "null" }
            }
          }
        },
        {
          "if": {
            "required": ["status"],
            "properties": {
              "status": { "const": "confirmed" }
            }
          },
          "then": {
            "properties": {
              "requiresConfirmation": { "const": true },
              "confirmedByMemberId": { "$ref": "#/$defs/uuid" },
              "confirmedAt": { "$ref": "#/$defs/dateTime" },
              "executedAt": { "type": "null" }
            }
          }
        },
        {
          "if": {
            "required": ["status"],
            "properties": {
              "status": { "const": "rejected" }
            }
          },
          "then": {
            "properties": {
              "requiresConfirmation": { "const": true },
              "confirmedByMemberId": { "type": "null" },
              "confirmedAt": { "type": "null" },
              "executedAt": { "type": "null" }
            }
          }
        },
        {
          "if": {
            "required": ["status"],
            "properties": {
              "status": { "const": "executed" }
            }
          },
          "then": {
            "properties": {
              "executedAt": { "$ref": "#/$defs/dateTime" }
            }
          }
        },
        {
          "if": {
            "required": ["requiresConfirmation", "status"],
            "properties": {
              "requiresConfirmation": { "const": true },
              "status": { "const": "executed" }
            }
          },
          "then": {
            "properties": {
              "confirmedByMemberId": { "$ref": "#/$defs/uuid" },
              "confirmedAt": { "$ref": "#/$defs/dateTime" }
            }
          }
        },
        {
          "if": {
            "required": ["status"],
            "properties": {
              "status": { "const": "failed" }
            }
          },
          "then": {
            "properties": {
              "requiresConfirmation": { "const": true },
              "confirmedByMemberId": { "$ref": "#/$defs/uuid" },
              "confirmedAt": { "$ref": "#/$defs/dateTime" },
              "executedAt": { "type": "null" }
            }
          }
        }
      ],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "runId": { "$ref": "#/$defs/uuid" },
        "type": {
          "enum": ["task.create.draft", "task.update.status", "github.issue.create", "meeting.report.generate", "review.analysis.generate", "planning.approve"]
        },
        "source": { "enum": ["meeting", "task", "github", "review", "planning", "orchestrator"] },
        "requiresConfirmation": { "type": "boolean" },
        "payload": { "type": "object" },
        "status": { "enum": ["draft", "waiting_confirmation", "confirmed", "executed", "rejected", "failed"] },
        "confirmedByMemberId": { "anyOf": [{ "$ref": "#/$defs/uuid" }, { "type": "null" }] },
        "confirmedAt": { "anyOf": [{ "$ref": "#/$defs/dateTime" }, { "type": "null" }] },
        "executedAt": { "anyOf": [{ "$ref": "#/$defs/dateTime" }, { "type": "null" }] }
      }
    },
    "AgentAction": {
      "oneOf": [
        {
          "allOf": [
            { "$ref": "#/$defs/AgentActionCommon" },
            {
              "type": "object",
              "properties": {
                "type": { "const": "task.create.draft" },
                "payload": { "$ref": "#/$defs/TaskCreateDraft" }
              }
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/AgentActionCommon" },
            {
              "type": "object",
              "properties": {
                "type": { "const": "task.update.status" },
                "payload": { "$ref": "#/$defs/TaskStatusUpdateAction" }
              }
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/AgentActionCommon" },
            {
              "type": "object",
              "properties": {
                "type": { "const": "github.issue.create" },
                "payload": { "$ref": "#/$defs/GithubIssueCreateAction" }
              }
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/AgentActionCommon" },
            {
              "type": "object",
              "properties": {
                "type": { "const": "meeting.report.generate" },
                "payload": { "$ref": "#/$defs/MeetingReportGenerateAction" }
              }
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/AgentActionCommon" },
            {
              "type": "object",
              "properties": {
                "type": { "const": "review.analysis.generate" },
                "payload": { "$ref": "#/$defs/ReviewAnalysisGenerateAction" }
              }
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/AgentActionCommon" },
            {
              "type": "object",
              "properties": {
                "type": { "const": "planning.approve" },
                "payload": { "$ref": "#/$defs/PlanningApproveAction" }
              }
            }
          ]
        }
      ]
    },
    "AgentJobMessage": {
      "type": "object",
      "required": ["jobId", "runId", "workflowType", "workflowVersion", "workspaceId", "actorMemberId", "input", "contextRefs", "requestedAt"],
      "additionalProperties": false,
      "properties": {
        "jobId": { "$ref": "#/$defs/uuid" },
        "runId": { "$ref": "#/$defs/uuid" },
        "workflowType": { "$ref": "#/$defs/AgentWorkflowType" },
        "workflowVersion": { "type": "string" },
        "workspaceId": { "$ref": "#/$defs/uuid" },
        "actorMemberId": { "$ref": "#/$defs/uuid" },
        "input": { "type": "object" },
        "contextRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/AgentContextRef" }
        },
        "requestedAt": { "$ref": "#/$defs/dateTime" }
      }
    },
    "AgentResultMessage": {
      "type": "object",
      "required": ["jobId", "runId", "status", "output", "actions", "trace", "error", "finishedAt"],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "required": ["status"],
            "properties": {
              "status": { "const": "succeeded" }
            }
          },
          "then": {
            "properties": {
              "error": { "type": "null" }
            }
          }
        },
        {
          "if": {
            "required": ["status"],
            "properties": {
              "status": { "const": "failed" }
            }
          },
          "then": {
            "properties": {
              "error": {
                "type": "object",
                "required": ["message"],
                "additionalProperties": false,
                "properties": {
                  "code": { "type": ["string", "null"] },
                  "message": { "type": "string" }
                }
              }
            }
          }
        }
      ],
      "properties": {
        "jobId": { "$ref": "#/$defs/uuid" },
        "runId": { "$ref": "#/$defs/uuid" },
        "status": { "enum": ["succeeded", "failed"] },
        "output": { "type": "object" },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/AgentAction" }
        },
        "trace": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["message"],
            "additionalProperties": false,
            "properties": {
              "stepName": { "type": ["string", "null"] },
              "message": { "type": "string" },
              "metadata": { "type": "object" }
            }
          }
        },
        "error": {
          "anyOf": [
            { "type": "null" },
            {
              "type": "object",
              "required": ["message"],
              "additionalProperties": false,
              "properties": {
                "code": { "type": ["string", "null"] },
                "message": { "type": "string" }
              }
            }
          ]
        },
        "finishedAt": { "$ref": "#/$defs/dateTime" }
      }
    },
    "NotificationCreateRequest": {
      "type": "object",
      "required": ["userId", "type", "title"],
      "additionalProperties": false,
      "properties": {
        "userId": { "$ref": "#/$defs/uuid" },
        "type": { "type": "string" },
        "title": { "type": "string" },
        "linkedEntityType": { "type": ["string", "null"] },
        "linkedEntityId": { "anyOf": [{ "$ref": "#/$defs/uuid" }, { "type": "null" }] }
      }
    },
    "SharedFileRef": {
      "type": "object",
      "required": ["id", "workspaceId", "filename", "url"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "workspaceId": { "$ref": "#/$defs/uuid" },
        "filename": { "type": "string" },
        "fileType": { "type": ["string", "null"] },
        "url": { "type": "string" },
        "linkedEntityType": { "type": ["string", "null"] },
        "linkedEntityId": { "anyOf": [{ "$ref": "#/$defs/uuid" }, { "type": "null" }] }
      }
    }
  }
}
